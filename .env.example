DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id

# Optional: fallback single guild for slash-command deployment.
GUILD_ID=your_main_guild_id

# Optional: comma-separated guild IDs for multi-guild slash-command deployment.
GUILD_IDS=your_first_guild_id,your_second_guild_id

# Optional: guild where admin commands are deployed.
GUILD_ID_ADMIN=your_admin_guild_id

# Optional: guild/channel used to store generated card images.
IMAGES_STORAGE_GUILD_ID=your_images_storage_guild_id
IMAGES_STORAGE_CHANNEL_ID=your_images_storage_channel_id
